# Supabase — get these from supabase.com → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# App URL — change to your Vercel URL after deploy
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HASA legacy CMS admin (used by /admin/login cookie flow). Pick a long random
# string; share only with HASA board members who need access to the legacy
# JSON-based admin panel. To be deprecated after the new CMS replaces it.
ADMIN_DASHBOARD_KEY=change-me-to-a-long-random-string

# New CMS admin email allowlist (comma-separated, no spaces). Only these
# emails can sign in at admin.harvardafricans.com. Defense in depth on top
# of password + TOTP.
ADMIN_EMAIL_ALLOWLIST=harvardasa@gmail.com,danditilahun82@gmail.com
